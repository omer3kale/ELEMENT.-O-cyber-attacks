# ELEMENT.İO — environment configuration
# Copy this file to .env and adjust values for your deployment.
# The scripts do NOT auto-load .env — export variables in your shell,
# systemd unit, or container environment instead.

# ── Data directory ────────────────────────────────────────────────────────────
# Base directory where per-tenant SQLite files are stored.
DATA_DIR=./data

# ── Timezone ──────────────────────────────────────────────────────────────────
# PHP timezone used for office-hours and holiday calculations.
# Full list: https://www.php.net/manual/en/timezones.php
TZ=UTC

# ── Tenant list (hosted-operator use) ─────────────────────────────────────────
# Comma-separated slug list read by bin/run-all-tenants.php.
# TENANTS=acme-corp,globex-inc,initech

# Path to a JSON file containing a flat array of tenant slugs.
# TENANTS_FILE=/etc/element-io/tenants.json
