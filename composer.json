{
    "name": "element-o/cyber-attacks",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "antlr/antlr4-php-runtime": "^0.9",
        "ramsey/uuid": "^4.7"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "ElementO\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ElementO\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
